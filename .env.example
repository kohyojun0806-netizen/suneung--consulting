TRACKER_REPORT_MAX_TOKENS=380
TRACKER_CONSULT_MAX_TOKENS=320
TRACKER_REPORT_LOG_WEEKS=3
REQUEST_BODY_LIMIT=2mb
ENABLE_SECURITY_HEADERS=true
ENABLE_RATE_LIMIT=true
