RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_ANALYZE_MAX=40
RATE_LIMIT_REPORT_MAX=80
RATE_LIMIT_CONSULT_MAX=80
ENFORCE_API_SHARED_SECRET=false
API_SHARED_SECRET=
